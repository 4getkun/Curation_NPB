---
import Base from "../layouts/Base.astro";
import { withBase } from "../lib/url";
---

<Base title="ページが見つかりません">
  <section class="container-page py-24 text-center">
    <p class="text-6xl">⚾</p>
    <h1 class="font-display mt-4 text-2xl font-black text-ink-900 dark:text-white">
      ページが見つかりませんでした
    </h1>
    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
      お探しのページは移動または削除された可能性があります。
    </p>
    <a
      href={withBase("/")}
      class="mt-8 inline-block rounded-full bg-accent-500 px-6 py-3 text-sm font-bold text-white hover:bg-accent-600 transition-colors"
    >
      トップページへ戻る
    </a>
  </section>
</Base>
