---
import Base from "../layouts/Base.astro";
import FeaturedNews from "../components/FeaturedNews.astro";
import NewsRow from "../components/NewsRow.astro";
import TeamLinkRow from "../components/TeamLinkRow.astro";
import { allNews, newsGeneratedAt, formatGeneratedAt } from "../lib/news";
import { centralTeams, pacificTeams } from "../lib/teams";
import { withBase } from "../lib/url";

const [featured, ...rest] = allNews;
const latest = rest.slice(0, 5);
---

<Base title="NPB Curation" description="広告ゼロで読める、NPB(日本プロ野球)12球団の最新ニュース・まとめキュレーションサイト。">
  <!-- Hero -->
  <section style="background-color:var(--hero-bg); color:var(--hero-text); position:relative; overflow:hidden;">
    <div class="container-page relative" style="padding:76px 24px 56px;">
      <div style={`width:44px; height:3px; background-color:var(--accent); margin-bottom:22px;`}></div>
      <p
        class="font-bold uppercase m-0"
        style="font-size:12px; letter-spacing:0.14em; color:var(--hero-muted); margin-bottom:18px;"
      >
        広告ゼロ・トラッキングなしのNPBキュレーション
      </p>
      <h1
        class="font-display font-black text-balance m-0"
        style="font-size:clamp(32px,5vw,58px); line-height:1.12; letter-spacing:-0.01em; margin-bottom:20px; max-width:720px;"
      >
        12球団のニュースを、<br class="hidden sm:block" />ノイズなく一箇所で。
      </h1>
      <p class="m-0" style="font-size:16px; line-height:1.8; color:var(--hero-muted); max-width:520px; margin-bottom:34px;">
        セ・パ12球団の最新ニュースと話題を自動収集。バナー広告も追跡もない、読むことだけに集中できるキュレーションサイトです。
      </p>
      <div class="flex flex-wrap gap-3" style="margin-bottom:28px;">
        <a
          href={withBase("/news/")}
          class="no-underline font-bold"
          style="background-color:var(--accent); color:#fff; padding:14px 28px; border-radius:2px; font-size:14px;"
        >
          最新ニュース一覧を見る
        </a>
        <a
          href={withBase("/team/")}
          class="no-underline font-bold"
          style="background:none; color:var(--hero-text); border:1px solid rgb(255 255 255 / 28%); padding:14px 28px; border-radius:2px; font-size:14px;"
        >
          球団から探す
        </a>
      </div>
      {newsGeneratedAt && (
        <p class="m-0" style="font-size:12px; color:var(--hero-muted);">
          最終更新: {formatGeneratedAt(newsGeneratedAt)}（自動更新）
        </p>
      )}
    </div>
  </section>

  <!-- Featured + Latest -->
  <section class="container-page" style="padding:56px 24px;">
    <div
      class="flex items-baseline justify-between"
      style="border-bottom:2px solid var(--text); padding-bottom:12px; margin-bottom:28px;"
    >
      <h2 class="font-display font-black m-0" style="font-size:22px; color:var(--text);">最新ニュース</h2>
      <a href={withBase("/news/")} class="no-underline font-bold" style="font-size:13px; color:var(--accent);">すべて見る →</a>
    </div>

    {featured ? (
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-10">
        <FeaturedNews item={featured} />
        <div>
          {latest.map((item) => (
            <NewsRow item={item} variant="compact" />
          ))}
        </div>
      </div>
    ) : (
      <p style="font-size:14px; color:var(--text-muted);">
        まだニュースが取得されていません。GitHub Actions の自動収集ワークフローが実行されると、ここに最新記事が並びます。
      </p>
    )}
  </section>

  <!-- Team access -->
  <section style="background-color:var(--card-bg); border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding:56px 0;">
    <div class="container-page">
      <h2 class="font-display font-black m-0" style="font-size:22px; color:var(--text); margin-bottom:6px;">球団から探す</h2>
      <p style="font-size:14px; color:var(--text-muted); margin-bottom:28px;">セ・リーグ、パ・リーグ全12球団のニュースをチームごとに確認できます。</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
        <div>
          <p class="font-bold" style="font-size:11px; letter-spacing:0.1em; color:var(--text-faint); margin-bottom:10px;">セントラル・リーグ</p>
          {centralTeams.map((team) => (
            <TeamLinkRow team={team} />
          ))}
        </div>
        <div>
          <p class="font-bold" style="font-size:11px; letter-spacing:0.1em; color:var(--text-faint); margin-bottom:10px;">パシフィック・リーグ</p>
          {pacificTeams.map((team) => (
            <TeamLinkRow team={team} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Value props (hairline grid) -->
  <section class="container-page" style="padding:56px 24px;">
    <div class="grid grid-cols-1 sm:grid-cols-3" style="gap:1px; background-color:var(--border); border:1px solid var(--border);">
      <div class="hairline-cell">
        <span class="inline-block rounded-[2px]" style="width:10px; height:10px; background-color:var(--accent);"></span>
        <p class="font-bold m-0" style="font-size:15px; color:var(--text); margin:14px 0 6px;">広告・トラッキング一切なし</p>
        <p class="m-0" style="font-size:13px; color:var(--text-muted); line-height:1.7;">バナー広告や追跡スクリプトを使わず、記事を読むことに集中できます。</p>
      </div>
      <div class="hairline-cell">
        <span class="inline-block rounded-[2px]" style="width:10px; height:10px; background-color:var(--accent);"></span>
        <p class="font-bold m-0" style="font-size:15px; color:var(--text); margin:14px 0 6px;">自動更新のキュレーション</p>
        <p class="m-0" style="font-size:13px; color:var(--text-muted); line-height:1.7;">複数の野球専門メディアのRSSを定期的に集約し、球団別に自動振り分けしています。</p>
      </div>
      <div class="hairline-cell">
        <span class="inline-block rounded-[2px]" style="width:10px; height:10px; background-color:var(--accent);"></span>
        <p class="font-bold m-0" style="font-size:15px; color:var(--text); margin:14px 0 6px;">高速な静的サイト</p>
        <p class="m-0" style="font-size:13px; color:var(--text-muted); line-height:1.7;">GitHub Pages上の静的サイトとして配信しているため表示が軽快です。</p>
      </div>
    </div>
  </section>
</Base>
