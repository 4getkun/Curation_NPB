---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../lib/url";

interface Props {
  title: string;
  description?: string;
  /** public/ 直下の画像ファイル名(サイト共通のOGP画像。ページ個別に差し替えたい場合だけ指定する) */
  image?: string;
}

const {
  title,
  description = "広告ゼロで読める、NPB(日本プロ野球)12球団のニュース・まとめキュレーションサイト。",
  image = "og-image.png",
} = Astro.props;

const pageTitle = title === "Curation NPB" ? title : `${title} | Curation NPB`;

// TwitterやFacebook等のOGPクローラーはBASE_URLのようなサイト内相対パスを解釈できず、
// 絶対URLでないとカードに画像が出ない。Astro.site は origin のみ(例:
// "https://4getkun.github.io/")を返すため、リポジトリ名を含むbaseパス
// (withBase())と組み合わせて絶対URLを組み立てる。Astro.url.pathname は
// ビルド時点で既にbaseを含んだ最終パスを返す(例: "/Curation_NPB/team/giants/")ので、
// そのままAstro.siteと結合すればページごとの正しい絶対URLになる。
const ogImageAbsoluteUrl = new URL(withBase(`/${image}`), Astro.site).toString();
const canonicalAbsoluteUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚾</text></svg>" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#111114" />
    <link rel="manifest" href={withBase("/manifest.webmanifest")} />
    <link rel="apple-touch-icon" href={withBase("/icons/icon-192.png")} />
    <link rel="canonical" href={canonicalAbsoluteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Curation NPB" />
    <meta property="og:url" content={canonicalAbsoluteUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsoluteUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsoluteUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Zen+Kaku+Gothic+New:wght@500;700;900&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // ダークモード初期化(フラッシュ防止のため <head> 内でインライン実行)
      const stored = localStorage.getItem("npb-curation-theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (stored === "dark" || (!stored && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:m-2 focus:rounded focus:bg-[var(--card-bg)] focus:px-3 focus:py-2 focus:text-[var(--text)]"
    >
      本文へスキップ
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <script define:vars={{ swUrl: `${import.meta.env.BASE_URL}sw.js` }}>
      // PWA対応: ホーム画面への追加とオフライン閲覧のためのService Worker登録。
      // 未対応ブラウザでは単純に何も起きない(機能低下するだけで壊れない)。
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register(swUrl).catch(() => {});
        });
      }
    </script>
  </body>
</html>
