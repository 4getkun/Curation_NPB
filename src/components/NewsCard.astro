---
import type { NewsItem } from "../lib/news";
import { formatRelativeOrDate } from "../lib/news";
import TeamBadge from "./TeamBadge.astro";

interface Props {
  item: NewsItem;
  featured?: boolean;
}

const { item, featured = false } = Astro.props;
---

<article class:list={["card group flex flex-col overflow-hidden", featured && "sm:flex-row"]}>
  <a
    href={item.link}
    target="_blank"
    rel="noopener noreferrer nofollow"
    class="flex flex-col gap-3 p-5 flex-1"
  >
    <div class="flex flex-wrap items-center gap-1.5">
      {item.teams.slice(0, 3).map((teamId) => (
        <TeamBadge teamId={teamId} linked={false} />
      ))}
      <span class="ml-auto text-xs font-medium text-slate-400">
        {formatRelativeOrDate(item.pubDate)}
      </span>
    </div>

    <h3
      class:list={[
        "font-bold text-ink-900 dark:text-white leading-snug group-hover:text-accent-600 transition-colors",
        featured ? "text-xl line-clamp-3" : "text-base line-clamp-2",
      ]}
    >
      {item.title}
    </h3>

    {item.summary && (
      <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">
        {item.summary}
      </p>
    )}

    <div class="mt-auto flex items-center gap-1 text-xs font-bold text-slate-400">
      <span>{item.source}</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 17L17 7M17 7H8M17 7v9" />
      </svg>
    </div>
  </a>
</article>
