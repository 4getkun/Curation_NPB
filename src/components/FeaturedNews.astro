---
import type { NewsItem } from "../lib/news";
import { formatRelativeShort } from "../lib/news";
import { getTeam, needsContrastRing } from "../lib/teams";

interface Props {
  item: NewsItem;
}

const { item } = Astro.props;
const primary = item.teams[0] ? getTeam(item.teams[0]) : undefined;
const dotColor = primary?.color ?? "var(--text-faint)";
const teamShort = primary?.short ?? "総合";
const dotRing = primary && needsContrastRing(primary.color) ? " box-shadow:0 0 0 1px var(--text-faint);" : "";
---

<a href={item.link} target="_blank" rel="noopener noreferrer nofollow" class="block no-underline" style="color:inherit;">
  <div class="photo-placeholder flex items-center justify-center mb-4" style="aspect-ratio:16/9;">
    <span
      class="font-mono"
      style="font-size:11px; color:var(--text-faint); background-color:var(--page-bg); padding:4px 10px;"
    >
      試合写真 差し替え
    </span>
  </div>
  <div class="flex items-center gap-2 mb-2.5">
    <span class="inline-block h-2 w-2 rounded-full" style={`background-color:${dotColor};${dotRing}`}></span>
    <span class="font-bold" style="font-size:12px; color:var(--text-muted);">{teamShort}</span>
    <span style="font-size:12px; color:var(--text-faint);">{formatRelativeShort(item.pubDate)}</span>
  </div>
  <h3 class="font-display font-black leading-snug m-0 mb-2.5" style="font-size:24px; color:var(--text);">
    {item.title}
  </h3>
  <p class="m-0" style="font-size:14px; line-height:1.7; color:var(--text-muted);">
    {item.summary}
  </p>
</a>
